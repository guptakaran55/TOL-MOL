<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#111827"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Symbol + Phase -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/holdSymbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RELIANCE"
                    android:textColor="#f1f5f9"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/holdPhase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="BULLISH"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="#059669"
                    android:background="@drawable/badge_phase_bg" />
            </LinearLayout>

            <TextView
                android:id="@+id/holdInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="10 qty · Avg ₹2,450"
                android:textColor="#475569"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Pullback / Momentum / Profit Booking / Capital Protection scores -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/holdBuyScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Pb72/Mo68"
                android:textColor="#059669"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/score_buy_bg" />

            <TextView
                android:id="@+id/holdProfitScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="P28"
                android:textColor="#f97316"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/score_sell_bg" />

            <TextView
                android:id="@+id/holdProtectScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="C12"
                android:textColor="#eab308"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/score_sell_bg" />
        </LinearLayout>

        <!-- Verdict -->
        <TextView
            android:id="@+id/holdVerdict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="HOLD"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#94a3b8"
            android:background="@drawable/badge_hold_bg" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
